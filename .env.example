# OpenEvidence credentials (single user)
OPENEVIDENCE_EMAIL=your_email@example.com
OPENEVIDENCE_PASSWORD=your_password

# Vault encryption key (multi-user SaaS)
# Generate a strong random key for production
OPENEVIDENCE_VAULT_KEY=change-me-to-a-strong-random-key

# Optional: FastAPI settings
# HOST=0.0.0.0
# PORT=8000
